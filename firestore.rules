/**
 * This ruleset enforces a strict admin-ownership model for a student birthday reminder application.
 *
 * Core Philosophy:
 * Access is granted based on two conditions: the user must be the designated owner of the data, AND they must be a registered administrator. This ensures a high level of security, suitable for managing sensitive student information.
 *
 * Data Structure:
 * The data is organized into two main paths:
 * 1. A top-level `/admins` collection, where the existence of a document `/admins/{userId}` grants administrative privileges to that user.
 * 2. A nested `/professors/{professorId}/students/{studentId}` collection, which scopes student data directly under the professor (admin) who owns it. This structure inherently links data ownership to the path.
 *
 * Key Security Decisions:
 * - Admin Creation Disabled: Admin roles cannot be created via client-side requests. The initial admin user must be added manually through the Firebase Console to prevent privilege escalation vulnerabilities.
 * - No Public Access: All data is private. There are no publicly readable collections.
 * - Strict Ownership: A professor can only access the student records under their own `professorId`. They cannot see or modify data belonging to other professors.
 * - Denormalization for Authorization: Admin status is checked via an `exists()` call to the `/admins` collection, avoiding slow, complex, or impossible lookups. Data ownership is enforced using the `{professorId}` wildcard directly from the document path. This makes authorization checks fast and atomic.
 * - Structural Segregation: Storing each professor's students in a dedicated subcollection (`/professors/{professorId}/students/...`) provides strong security and performance boundaries, ensuring queries for one professor's data can never accidentally leak another's.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     * This is the fundamental check for document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the authenticated user is a registered administrator by verifying
     * the existence of their UID in the /admins collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    /**
     * A composite check for update/delete operations on professor-owned data.
     * It verifies that the document exists, the user is the owner, and the user is an admin.
     */
    function isExistingOwnerAndAdmin(professorId) {
      return resource != null && isOwner(professorId) && isAdmin();
    }

    /**
     * Validates required relational fields on student creation.
     * Ensures the document's internal ID matches its path ID for consistency.
     */
    function hasValidStudentDataOnCreate(studentId) {
      return request.resource.data.id == studentId;
    }

    /**
     * Enforces immutability for critical relational fields on student updates.
     * Prevents re-assigning the document's core identifier.
     */
    function hasImmutableStudentFields() {
      return request.resource.data.id == resource.data.id;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    /**
     * @description Manages administrator roles. The existence of a document here grants admin privileges.
     * @path /admins/{adminId}
     * @allow (get) An admin retrieving their own admin document: `get /admins/my-admin-uid` (auth.uid = 'my-admin-uid').
     * @deny (create) Any user trying to make themselves an admin: `create /admins/my-user-uid` (fails because creation is disabled).
     * @principle Prevents privilege escalation by disallowing client-side creation of admin roles.
     */
    match /admins/{adminId} {
      allow get: if isOwner(adminId);
      allow list: if false;
      allow create: if false;
      allow update: if isOwner(adminId) && resource != null;
      allow delete: if isOwner(adminId) && resource != null;
    }

    /**
     * @description Defines rules for student documents, which are owned by a specific professor (admin).
     * @path /professors/{professorId}/students/{studentId}
     * @allow (create) An authenticated admin adding a student to their own list: `create /professors/my-admin-uid/students/new-student-id` (auth.uid = 'my-admin-uid', and `/admins/my-admin-uid` exists).
     * @deny (get) A non-admin user trying to read student data: `get /professors/some-admin-uid/students/some-student-id` (fails isAdmin() check).
     * @deny (list) An admin trying to list another admin's students: `list /professors/other-admin-uid/students` (fails isOwner() check).
     * @principle Enforces a strict ownership model where only a verified administrator can access their own data tree.
     */
    match /professors/{professorId}/students/{studentId} {
      allow get: if isOwner(professorId) && isAdmin();
      allow list: if isOwner(professorId) && isAdmin();
      allow create: if isOwner(professorId) && isAdmin() && hasValidStudentDataOnCreate(studentId);
      allow update: if isExistingOwnerAndAdmin(professorId) && hasImmutableStudentFields();
      allow delete: if isExistingOwnerAndAdmin(professorId);
    }
  }
}